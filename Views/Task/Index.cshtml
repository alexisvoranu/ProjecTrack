@model IEnumerable<Licenta3.Models.Task>

@{
	ViewData["Title"] = "Index";
}

<style>

	.container p, .container h2, .container table, .container td, .container th {
		color: black;
	}

	.container table, .container td, .container th {
		text-align: center;
		vertical-align: middle;
	}
</style>


<div class="container p-3">
	<div class="row pt-4">
		<div class="col-6">
			<h2 class="text-primary">Estimările proiectelor</h2>
		</div>
		<div class="col-6 d-flex justify-content-end">
			<a asp-controller="Task" asp-action="Create" class="btn btn-primary me-2">
				<i class="bi bi-plus-circle"></i> &nbsp; Adaugă o nouă activitate
			</a>
			@* <a asp-controller="CriticalPath" asp-action="CalculateCriticalPath" class="btn btn-primary">
				<i class="bi bi-plus-circle"></i> &nbsp; Calculează estimarea
			</a> *@


		</div>
	</div>
</div>

	<br />

<table class="table table-bordered table-striped" style="width:100%">
		<thead>
			<tr>
				<th>
					Nr. crt.

				</th>

				<th>
					Codul activității
				</th>

				<th>
					Denumirea activității
				</th>

				<th>
					Condiționări
				</th>

				<th>
					Durată
				</th>
				<th>
					Acțiuni
				</th>


			</tr>
		</thead>
	<tbody>
			@foreach (var obj in Model)
			{
				<tr>
					<td width="20%">
						@obj.Id
					</td>

					<td width="20%">
						@obj.Code
					</td>

					<td width="20%">
						@obj.Name
					</td>

					<td width="20%">
						@obj.Dependencies
					</td>

					<td width="20%">
						@obj.Duration
					</td>

					<td>
						<div class="w-80 btn-group" role="group">
							<a asp-controller="Task" asp-action="Edit" asp-route-id="@obj.Id"
						   class="btn btn-outline-primary mx-2"><i class="bi bi-pencil-square"></i>Edit</a>

						<a asp-controller="Task" asp-action="Delete" asp-route-id="@obj.Id"
						   class="btn btn-outline-danger mx-2"><i class="bi bi-trash-fill"></i>Șterge</a>
						</div>
					</td>
				</tr>
			}
	</tbody>

</table>
